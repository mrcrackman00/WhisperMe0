# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=3000

# Supabase (from project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (from resend.com)
RESEND_API_KEY=re_...
FROM_EMAIL=WhisperMe <onboarding@resend.dev>
# Optional: Resend template ID for password reset (create in Resend dashboard, use email-templates/password-reset.html)
# RESEND_PASSWORD_RESET_TEMPLATE_ID=xxx-xxx-xxx

# Google reCAPTCHA v3 (https://www.google.com/recaptcha/admin — create v3 keys for your domain)
# If unset, waitlist skips captcha verification (fine for local dev only).
RECAPTCHA_SECRET_KEY=
# Optional: minimum score 0.0–1.0 (default 0.5)
# RECAPTCHA_MIN_SCORE=0.5

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5500

# Comma-separated emails allowed to access admin APIs
ADMIN_EMAILS=admin@yourdomain.com
